DJANGO_SECRET_KEY=change-this-local-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use mssql for the real local project. Use sqlite only for a quick test.
DB_ENGINE=mssql
DB_NAME=store_retail_db
DB_USER=store_app
DB_PASSWORD=ChangeThisStrongPassword!2026
# Named instance example: localhost\\SQLEXPRESS
# TCP example: localhost
DB_HOST=localhost\SQLEXPRESS
DB_PORT=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERTIFICATE=yes
DB_ENCRYPT=no
